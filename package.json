{
  "name": "ramin-starter-app.frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cap:sync": "npm run build && cap sync",
    "contract:generate": "openapi-typescript ../RaminStarterApp.Backend/openapi/ramin-api.json -o app/api/generated/ramin-api.ts",
    "dev": "react-router dev",
    "start": "vite preview --host 0.0.0.0 --outDir build/client",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc",
    "verify": "scripts/verify.sh"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "@tanstack/react-query": "^5.100.9",
    "isbot": "^5.1.36",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.15.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.2",
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  }
}
